# 同时配置多种模型，用 ACTIVE_MODEL 或启动参数 --model 指定当前使用哪一种。
# ACTIVE_MODEL 对应下方 MODEL_<ID>_ 的 <ID>（不区分大小写，连字符与下划线等价）。

ACTIVE_MODEL=google

# --- Google AI Studio / Gemini（免费 Key：https://aistudio.google.com/apikey）---
MODEL_GOOGLE_PROVIDER=GoogleAIStudio
MODEL_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
MODEL_GOOGLE_NAME=gemini-2.5-flash
MODEL_GOOGLE_API_KEY=your_api_key_here

# --- 硅基流动（免费额度）---
# MODEL_SILICONFLOW_PROVIDER=SiliconFlow
# MODEL_SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
# MODEL_SILICONFLOW_NAME=Qwen/Qwen2.5-7B-Instruct
# MODEL_SILICONFLOW_API_KEY=sk-xxxx

# --- DeepSeek ---
# MODEL_DEEPSEEK_PROVIDER=DeepSeek
# MODEL_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# MODEL_DEEPSEEK_NAME=deepseek-chat
# MODEL_DEEPSEEK_API_KEY=sk-xxxx

# 兼容旧版：若未配置任何 MODEL_<ID>_*，仍可用下方扁平四元组
# MODEL_PROVIDER=GoogleAIStudio
# BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# MODEL_NAME=gemini-2.5-flash
# API_KEY=your_api_key_here

# 数据库（与 crawler 共用）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=investment_radar
DB_USER=investment
DB_PASSWORD=123456
DB_SCHEMA=investment_radar

# 分析参数
PROMPT_VERSION=v1.0
AI_BATCH_SIZE=20
AI_MAX_RETRIES=3
AI_MAX_CONTENT_LENGTH=12000
AI_REQUEST_TIMEOUT=120
LLM_TEMPERATURE=0.1
