# 大模型配置（默认：Google AI Studio / Gemini，OpenAI Compatible）
# 获取免费 Key：https://aistudio.google.com/apikey
MODEL_PROVIDER=GoogleAIStudio
BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
MODEL_NAME=gemini-2.5-flash
API_KEY=your_api_key_here

# 其它可选提供商示例（按需替换上面 4 项）:
# --- 硅基流动（免费额度）---
# MODEL_PROVIDER=SiliconFlow
# BASE_URL=https://api.siliconflow.cn/v1
# MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
# API_KEY=sk-xxxx
#
# --- DeepSeek（付费）---
# MODEL_PROVIDER=DeepSeek
# BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat
# API_KEY=sk-xxxx

# 数据库（与 crawler 共用）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=investment_radar
DB_USER=investment
DB_PASSWORD=123456
DB_SCHEMA=investment_radar

# 分析参数
PROMPT_VERSION=v1.0
AI_BATCH_SIZE=20
AI_MAX_RETRIES=3
AI_MAX_CONTENT_LENGTH=12000
AI_REQUEST_TIMEOUT=120
LLM_TEMPERATURE=0.1
