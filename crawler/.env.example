# Crawler config (copy to .env). Shared DB settings with ai-analysis / backend.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=investment_radar
DB_USER=investment
DB_PASSWORD=123456
DB_SCHEMA=investment_radar

# CNINFO
CNINFO_QUERY_URL=https://www.cninfo.com.cn/new/hisAnnouncement/query
CNINFO_STATIC_BASE=https://static.cninfo.com.cn/
CNINFO_INDEX_URL=https://www.cninfo.com.cn/new/index

# Crawl
CRAWLER_PAGE_SIZE=30
CRAWLER_REQUEST_TIMEOUT=30
CRAWLER_REQUEST_RETRY=3
CRAWLER_REQUEST_SLEEP=0.5
PDF_BATCH_LIMIT=50

# PDF (empty = crawler/data/pdf)
# PDF_STORAGE_DIR=
PARSER_NAME=PyMuPDF
